# ============================================================
#  VARIABLES DE ENTORNO - TIENDA NATURA JACQUY
# ------------------------------------------------------------
#  1) Copia este archivo y renombralo a  ".env.local"
#  2) Reemplaza los valores por los de TU proyecto de Supabase
#     (Supabase -> Project Settings -> Data API / API Keys)
#  3) NUNCA subas el archivo .env.local a internet.
# ============================================================

# URL de tu proyecto Supabase (ej: https://abcdxyz.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co

# Clave publica "anon" (empieza con eyJ...). Es segura para el navegador.
NEXT_PUBLIC_SUPABASE_ANON_KEY=TU_CLAVE_ANON_PUBLICA

# Numero de WhatsApp que RECIBE los pedidos.
# Formato internacional SIN + ni espacios. Ej Chile: 56912345678
NEXT_PUBLIC_WHATSAPP_NUMBER=56912345678

# Nombre de la tienda (aparece en la web)
NEXT_PUBLIC_STORE_NAME=Natura Jacquy
